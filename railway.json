{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "services": {
    "web": {
      "source": ".",
      "build": {
        "buildCommand": "npm run build",
        "watchPatterns": ["src/**", "public/**", "index.html", "vite.config.ts"]
      },
      "deploy": {
        "startCommand": "npx serve dist -l 3000",
        "healthcheckPath": "/",
        "healthcheckTimeout": 30
      },
      "variables": {
        "VITE_API_URL": "https://${{api.RAILWAY_PUBLIC_DOMAIN}}/api"
      }
    },
    "api": {
      "source": "apps/api",
      "build": {
        "buildCommand": "npm ci && npm run build",
        "watchPatterns": ["apps/api/src/**"]
      },
      "deploy": {
        "startCommand": "node dist/index.js",
        "healthcheckPath": "/api/health",
        "healthcheckTimeout": 30
      },
      "variables": {
        "NODE_ENV": "production",
        "API_PORT": "4000"
      }
    },
    "scraper": {
      "source": "services/scraper",
      "build": {
        "buildCommand": "npm ci && npm run build",
        "watchPatterns": ["services/scraper/src/**"]
      },
      "deploy": {
        "startCommand": "node dist/worker.js"
      },
      "variables": {
        "NODE_ENV": "production"
      }
    }
  }
}
